MOVIELENS_DATA_DIR=data/processed
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_ARTIFACT_ROOT=./mlruns
MLFLOW_EXPERIMENT_NAME=movielens-two-tower
MLFLOW_UI_HOST=127.0.0.1
MLFLOW_UI_PORT=5000
MLFLOW_UI_URL=http://127.0.0.1:5000
MODEL_OUTPUT_DIR=artifacts/models
INDEX_OUTPUT_DIR=artifacts/faiss
REPORT_OUTPUT_DIR=artifacts/reports
RANDOM_SEED=42
DEVICE=auto
TRAIN_BATCH_SIZE=256
EVAL_BATCH_SIZE=512
NUM_WORKERS=0
